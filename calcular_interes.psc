Algoritmo calcular_interes
    definir cap, tiempo, tasa, res como real
    tasa = 0.05 
	
    escribir "la tasa es del 5 por ciento"
    
	escribir "pone el capital:"
    leer cap
    escribir "pone el tiempo en ańos:"
